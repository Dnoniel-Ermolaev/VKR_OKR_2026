  {
    "id": "rag_uncertain_case_demo",
    "surface": "UI / case reassess",
    "purpose": "Показать двухшаговый сценарий: сначала data_quality_issue на вкладке 'Оценка ОКС', затем неочевидный кейс с принудительным LLM+RAG reassess.",
    "input": {
      "assessment_form": {
        "name": "Пациент RAG demo",
        "pain_type": "atypical",
        "ecg_changes": "ST-depression V4-V6, неспецифические ишемические изменения",
        "troponin": 0.08,
        "hr": 96,
        "bp": "145/90"
      },
      "case_enrichment": {
        "vitals": {
          "spo2": 96
        },
        "labs": [
          { "code": "troponin_i", "value": 0.08 },
          { "code": "creatinine_blood", "value": 98 }
        ],
        "studies": [
          { "code": "ecg_12", "status": "done", "result_text": "ST-depression V4-V6, неспецифические ишемические изменения" }
        ],
        "constraints": [
          "не добавлять диагноз I21.0",
          "не добавлять ST-elevation",
          "не добавлять выполненные ЧКВ/коронарографию"
        ]
      },
      "reassess_payload": {
        "llm_model": "qwen2.5:7b-instruct",
        "force_llm": true
      }
    },
    "expected": {
      "step_1": {
        "triage_category": "data_quality_issue",
        "llm_used": true,
        "citations": []
      },
      "step_2": {
        "triage_category": "diagnostic_uncertain",
        "llm_used": true,
        "citations_non_empty": true
      }
    }
  },
